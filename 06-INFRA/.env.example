# --- SEU DOMÍNIO ---
DOMINIO=seudominio.com.br

# --- EMAIL (para SSL do Let's Encrypt) ---
EMAIL_SSL=seuemail@gmail.com

# --- POSTGRESQL ---
POSTGRES_USER=saas_admin
POSTGRES_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE_AQUI
POSTGRES_DB=saas_whatsapp

# --- PORTAINER ---
# (senha será criada no primeiro acesso pelo navegador)

# --- NGINX PROXY MANAGER ---
# Login padrão inicial:
# Email: admin@example.com
# Senha: changeme
# (será trocado no primeiro acesso)

# --- EVOLUTION API ---
EVOLUTION_API_KEY=TROQUE_POR_UMA_API_KEY_MUITO_FORTE_E_ALEATORIA_AQUI

